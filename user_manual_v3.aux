\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Active Mappings} sidebar on the Monthly Transfer tab, showing loaded mapping cards for May 2025. Each card displays the source sheet, source column, destination sheet, and destination column. Cards with an amber \textbf  {Ignore} badge are excluded from the next transfer run. The \textbf  {Copy full sheet}, \textbf  {Target sheet name}, and \textbf  {Insert after sheet name} fields appear below cards that support full-sheet copying. The year/month selector on the right shows May 2025 highlighted.}}{11}{figure.6}\protected@file@percent }
\newlabel{fig:mappingcard}{{6}{11}{\textbf {Active Mappings} sidebar on the Monthly Transfer tab, showing loaded mapping cards for May 2025. Each card displays the source sheet, source column, destination sheet, and destination column. Cards with an amber \textbf {Ignore} badge are excluded from the next transfer run. The \textbf {Copy full sheet}, \textbf {Target sheet name}, and \textbf {Insert after sheet name} fields appear below cards that support full-sheet copying. The year/month selector on the right shows May 2025 highlighted}{figure.6}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {6.2.1}Understanding Mapping Cards}{12}{subsubsection.6.2.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Mapping card detail view} showing the expanded controls for a single mapping entry. The card displays the source file type (SAP Report), source sheet name, source column (C), destination sheet (MZLZ Consolidated), and destination column (BD). Below the main mapping information are action buttons: \textbf  {Edit Rows} (modify row mappings), \textbf  {Export} (save rowMap to JSON), \textbf  {Import} (load rowMap from JSON), and the amber \textbf  {Ignore} badge (toggle this mapping in/out of transfers). The checkbox at the top left controls whether this mapping is included in the next Execute All run.}}{13}{figure.7}\protected@file@percent }
\newlabel{fig:mappingdetail}{{7}{13}{\textbf {Mapping card detail view} showing the expanded controls for a single mapping entry. The card displays the source file type (SAP Report), source sheet name, source column (C), destination sheet (MZLZ Consolidated), and destination column (BD). Below the main mapping information are action buttons: \textbf {Edit Rows} (modify row mappings), \textbf {Export} (save rowMap to JSON), \textbf {Import} (load rowMap from JSON), and the amber \textbf {Ignore} badge (toggle this mapping in/out of transfers). The checkbox at the top left controls whether this mapping is included in the next Execute All run}{figure.7}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {6.2.2}Working with Mapping Card Controls}{13}{subsubsection.6.2.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Active Mappings} sidebar showing a mapping card for April 2025 with the \textbf  {Ignore} badge highlighted (amber). The card maps the \textit  {2025 FTE} source sheet (column G) to \textit  {MZLZ Consolidated} (column BD). Clicking the \textbf  {Ignore} badge on any card toggles it in or out of the next transfer run without removing the mapping. The \textbf  {Copy full sheet} checkbox and sheet name fields below the card allow full-sheet copy mode for supported mapping types.}}{14}{figure.8}\protected@file@percent }
\newlabel{fig:copyfullsheet}{{8}{14}{\textbf {Active Mappings} sidebar showing a mapping card for April 2025 with the \textbf {Ignore} badge highlighted (amber). The card maps the \textit {2025 FTE} source sheet (column G) to \textit {MZLZ Consolidated} (column BD). Clicking the \textbf {Ignore} badge on any card toggles it in or out of the next transfer run without removing the mapping. The \textbf {Copy full sheet} checkbox and sheet name fields below the card allow full-sheet copy mode for supported mapping types}{figure.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}Ignore Rows Dialog}{14}{subsection.6.3}\protected@file@percent }
\newlabel{sec:ignorerows}{{6.3}{14}{Ignore Rows Dialog}{subsection.6.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \textbf  {Edit Rows dialog} for modifying source and destination row mappings. The dialog shows a two-column table where each row defines a mapping pair: the left column lists source row numbers (from the source Excel file), and the right column lists corresponding destination row numbers (in the destination file). Users can add new row pairs using the \textbf  {+ Add Row} button, delete existing pairs with the \textbf  {Delete} button, or bulk-import/export mappings using the \textbf  {Import} and \textbf  {Export} buttons. Changes are applied immediately when clicking \textbf  {OK}.}}{15}{figure.9}\protected@file@percent }
\newlabel{fig:editrows}{{9}{15}{\textbf {Edit Rows dialog} for modifying source and destination row mappings. The dialog shows a two-column table where each row defines a mapping pair: the left column lists source row numbers (from the source Excel file), and the right column lists corresponding destination row numbers (in the destination file). Users can add new row pairs using the \textbf {+ Add Row} button, delete existing pairs with the \textbf {Delete} button, or bulk-import/export mappings using the \textbf {Import} and \textbf {Export} buttons. Changes are applied immediately when clicking \textbf {OK}}{figure.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Ignore Rows dialog for REFI CM $\rightarrow $ MZLZ Consolidated. Each rowMap entry shows Dest Row, Dest Column, Src Row(s), and Current Value. Check \textbf  {Skip} to exclude a row from the next transfer. The filter box narrows the list. Status line shows ``0 rows ignored out of 136''.}}{16}{figure.10}\protected@file@percent }
\newlabel{fig:ignorerows}{{10}{16}{Ignore Rows dialog for REFI CM $\rightarrow $ MZLZ Consolidated. Each rowMap entry shows Dest Row, Dest Column, Src Row(s), and Current Value. Check \textbf {Skip} to exclude a row from the next transfer. The filter box narrows the list. Status line shows ``0 rows ignored out of 136''}{figure.10}{}}
