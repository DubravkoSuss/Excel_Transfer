\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Individual Transfer} tab in its initial state. Browse for a \textit  {Source File} and \textit  {Destination File} using the \textbf  {Browse} buttons. Once files are loaded, the \textbf  {Select Source Cells (Graphical)} and \textbf  {Select Destination Cells (Graphical)} buttons become active for visual cell mapping. The \textit  {Transfer Mapping} table at the bottom shows all defined source-to-destination cell pairs ready for execution.}}{7}{figure.4}\protected@file@percent }
\newlabel{fig:logbutton}{{4}{7}{\textbf {Individual Transfer} tab in its initial state. Browse for a \textit {Source File} and \textit {Destination File} using the \textbf {Browse} buttons. Once files are loaded, the \textbf {Select Source Cells (Graphical)} and \textbf {Select Destination Cells (Graphical)} buttons become active for visual cell mapping. The \textit {Transfer Mapping} table at the bottom shows all defined source-to-destination cell pairs ready for execution}{figure.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Mapping Card Buttons}{7}{subsection.6.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Active Mappings} sidebar on the Monthly Transfer tab, showing loaded mapping cards for May 2025. Each card displays the source sheet, source column, destination sheet, and destination column. Cards with an amber \textbf  {Ignore} badge are excluded from the next transfer run. The \textbf  {Copy full sheet}, \textbf  {Target sheet name}, and \textbf  {Insert after sheet name} fields appear below cards that support full-sheet copying. The year/month selector on the right shows May 2025 highlighted.}}{8}{figure.5}\protected@file@percent }
\newlabel{fig:mappingcard}{{5}{8}{\textbf {Active Mappings} sidebar on the Monthly Transfer tab, showing loaded mapping cards for May 2025. Each card displays the source sheet, source column, destination sheet, and destination column. Cards with an amber \textbf {Ignore} badge are excluded from the next transfer run. The \textbf {Copy full sheet}, \textbf {Target sheet name}, and \textbf {Insert after sheet name} fields appear below cards that support full-sheet copying. The year/month selector on the right shows May 2025 highlighted}{figure.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}Ignore Rows Dialog}{8}{subsection.6.3}\protected@file@percent }
\newlabel{sec:ignorerows}{{6.3}{8}{Ignore Rows Dialog}{subsection.6.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Active Mappings} sidebar showing a mapping card for April 2025 with the \textbf  {Ignore} badge highlighted (amber). The card maps the \textit  {2025 FTE} source sheet (column G) to \textit  {MZLZ Consolidated} (column BD). Clicking the \textbf  {Ignore} badge on any card toggles it in or out of the next transfer run without removing the mapping. The \textbf  {Copy full sheet} checkbox and sheet name fields below the card allow full-sheet copy mode for supported mapping types.}}{9}{figure.6}\protected@file@percent }
\newlabel{fig:copyfullsheet}{{6}{9}{\textbf {Active Mappings} sidebar showing a mapping card for April 2025 with the \textbf {Ignore} badge highlighted (amber). The card maps the \textit {2025 FTE} source sheet (column G) to \textit {MZLZ Consolidated} (column BD). Clicking the \textbf {Ignore} badge on any card toggles it in or out of the next transfer run without removing the mapping. The \textbf {Copy full sheet} checkbox and sheet name fields below the card allow full-sheet copy mode for supported mapping types}{figure.6}{}}
