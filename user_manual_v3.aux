\@writefile{toc}{\contentsline {subsection}{\numberline {15.5}Hybrid Transfer Tab}{20}{subsection.15.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces The \textbf  {Hybrid Transfer} tab in its initial state. The left panel shows \textit  {Row Mappings} (mapping cards appear here once months are loaded). On the right, the \textit  {Assign Periods} section allows selecting a \textbf  {Year} (2026 shown) and \textbf  {Transfer Type} (\textit  {Execute All} or \textit  {Execute RT}). Individual months are checked via the month grid or the \textit  {Q1}--\textit  {Q4} / \textit  {All} / \textit  {None} quick-select buttons. Click \textbf  {+ Add Selected Months} to register the selection in the \textit  {Assigned Periods} table. The status bar reads ``Ready -- Select years and months, then click Load''.}}{21}{figure.12}\protected@file@percent }
\newlabel{fig:hybrid-empty}{{12}{21}{The \textbf {Hybrid Transfer} tab in its initial state. The left panel shows \textit {Row Mappings} (mapping cards appear here once months are loaded). On the right, the \textit {Assign Periods} section allows selecting a \textbf {Year} (2026 shown) and \textbf {Transfer Type} (\textit {Execute All} or \textit {Execute RT}). Individual months are checked via the month grid or the \textit {Q1}--\textit {Q4} / \textit {All} / \textit {None} quick-select buttons. Click \textbf {+ Add Selected Months} to register the selection in the \textit {Assigned Periods} table. The status bar reads ``Ready -- Select years and months, then click Load''}{figure.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces The \textbf  {Hybrid Transfer} tab with periods assigned and mapping cards loaded for February 2026. The left \textit  {Row Mappings} sidebar shows all mapping cards for the loaded month (SAP Report, REFI CM, Budget 2025 --- each with source/destination sheet and column, and an amber \textbf  {Ignore} badge where applicable). The \textit  {Transfer Type} dropdown on the right shows both options --- \textit  {Execute All} and \textit  {Execute RT} --- open for selection. The \textit  {Assigned Periods} table at the bottom lists three entries: February 2026 (\textit  {Execute All}, Pending), September 2026 (\textit  {Execute RT}, Pending), and October 2026 (\textit  {Execute RT}, Pending). Click \textbf  {Execute All} in the header toolbar to process all assigned periods.}}{22}{figure.13}\protected@file@percent }
\newlabel{fig:hybrid-loaded}{{13}{22}{The \textbf {Hybrid Transfer} tab with periods assigned and mapping cards loaded for February 2026. The left \textit {Row Mappings} sidebar shows all mapping cards for the loaded month (SAP Report, REFI CM, Budget 2025 --- each with source/destination sheet and column, and an amber \textbf {Ignore} badge where applicable). The \textit {Transfer Type} dropdown on the right shows both options --- \textit {Execute All} and \textit {Execute RT} --- open for selection. The \textit {Assigned Periods} table at the bottom lists three entries: February 2026 (\textit {Execute All}, Pending), September 2026 (\textit {Execute RT}, Pending), and October 2026 (\textit {Execute RT}, Pending). Click \textbf {Execute All} in the header toolbar to process all assigned periods}{figure.13}{}}
