\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Header Bar}{4}{subsection.4.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The \textbf  {application header bar} with the global toolbar buttons highlighted. From left to right: \textbf  {Execute All} (green) --- runs all checked mapping cards in sequence; \textbf  {Pause} (white) --- suspends the current transfer after the active cell write completes; \textbf  {Stop} (red) --- cancels execution immediately; \textbf  {Execute RT} (amber) --- starts a Rolling Transfer chain using the \textit  {Load RT} period; \textbf  {Reset} (dark) --- clears all loaded files, mapping cards, and period selections; \textbf  {Log} (dark) --- toggles the status log panel. The four tabs below give access to \textit  {Monthly Transfer}, \textit  {Fill All Months}, \textit  {Hybrid Transfer}, and \textit  {Individual Transfer}.}}{5}{figure.2}\protected@file@percent }
\newlabel{fig:toolbar}{{2}{5}{The \textbf {application header bar} with the global toolbar buttons highlighted. From left to right: \textbf {Execute All} (green) --- runs all checked mapping cards in sequence; \textbf {Pause} (white) --- suspends the current transfer after the active cell write completes; \textbf {Stop} (red) --- cancels execution immediately; \textbf {Execute RT} (amber) --- starts a Rolling Transfer chain using the \textit {Load RT} period; \textbf {Reset} (dark) --- clears all loaded files, mapping cards, and period selections; \textbf {Log} (dark) --- toggles the status log panel. The four tabs below give access to \textit {Monthly Transfer}, \textit {Fill All Months}, \textit {Hybrid Transfer}, and \textit {Individual Transfer}}{figure.2}{}}
