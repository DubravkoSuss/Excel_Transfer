\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces The \textbf  {Hybrid Transfer} tab in its initial state. The left panel shows \textit  {Row Mappings} (mapping cards appear here once months are loaded). On the right, the \textit  {Assign Periods} section allows selecting a \textbf  {Year} (2026 shown) and \textbf  {Transfer Type} (\textit  {Execute All} or \textit  {Execute RT}). Individual months are checked via the month grid or the \textit  {Q1}--\textit  {Q4} / \textit  {All} / \textit  {None} quick-select buttons. Click \textbf  {+ Add Selected Months} to register the selection in the \textit  {Assigned Periods} table. The status bar reads ``Ready -- Select years and months, then click Load''.}}{30}{figure.15}\protected@file@percent }
\newlabel{fig:hybrid-empty}{{15}{30}{The \textbf {Hybrid Transfer} tab in its initial state. The left panel shows \textit {Row Mappings} (mapping cards appear here once months are loaded). On the right, the \textit {Assign Periods} section allows selecting a \textbf {Year} (2026 shown) and \textbf {Transfer Type} (\textit {Execute All} or \textit {Execute RT}). Individual months are checked via the month grid or the \textit {Q1}--\textit {Q4} / \textit {All} / \textit {None} quick-select buttons. Click \textbf {+ Add Selected Months} to register the selection in the \textit {Assigned Periods} table. The status bar reads ``Ready -- Select years and months, then click Load''}{figure.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces The \textbf  {Hybrid Transfer} tab with periods assigned and mapping cards loaded for February 2026. The left \textit  {Row Mappings} sidebar shows all mapping cards for the loaded month (SAP Report, REFI CM, Budget 2025 --- each with source/destination sheet and column, and an amber \textbf  {Ignore} badge where applicable). The \textit  {Transfer Type} dropdown on the right shows both options --- \textit  {Execute All} and \textit  {Execute RT} --- open for selection. The \textit  {Assigned Periods} table at the bottom lists three entries: February 2026 (\textit  {Execute All}, Pending), September 2026 (\textit  {Execute RT}, Pending), and October 2026 (\textit  {Execute RT}, Pending). Click \textbf  {Execute All} in the header toolbar to process all assigned periods.}}{31}{figure.16}\protected@file@percent }
\newlabel{fig:hybrid-loaded}{{16}{31}{The \textbf {Hybrid Transfer} tab with periods assigned and mapping cards loaded for February 2026. The left \textit {Row Mappings} sidebar shows all mapping cards for the loaded month (SAP Report, REFI CM, Budget 2025 --- each with source/destination sheet and column, and an amber \textbf {Ignore} badge where applicable). The \textit {Transfer Type} dropdown on the right shows both options --- \textit {Execute All} and \textit {Execute RT} --- open for selection. The \textit {Assigned Periods} table at the bottom lists three entries: February 2026 (\textit {Execute All}, Pending), September 2026 (\textit {Execute RT}, Pending), and October 2026 (\textit {Execute RT}, Pending). Click \textbf {Execute All} in the header toolbar to process all assigned periods}{figure.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces \textbf  {Transfer progress dialog} showing real-time status during an Execute All operation. The dialog displays the current operation (``Transferring data...''), a progress bar indicating completion percentage, and the current mapping being processed (e.g., ``Processing SAP Report → MZLZ Consolidated''). The \textbf  {Cancel} button allows users to abort the transfer mid-execution. Status messages update continuously as each mapping card completes.}}{32}{figure.17}\protected@file@percent }
\newlabel{fig:progress}{{17}{32}{\textbf {Transfer progress dialog} showing real-time status during an Execute All operation. The dialog displays the current operation (``Transferring data...''), a progress bar indicating completion percentage, and the current mapping being processed (e.g., ``Processing SAP Report → MZLZ Consolidated''). The \textbf {Cancel} button allows users to abort the transfer mid-execution. Status messages update continuously as each mapping card completes}{figure.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces \textbf  {Log panel} (toggled visible via the \textbf  {Log} button in the header) showing detailed transfer execution logs. Each log entry includes a timestamp, severity level (INFO, WARNING, ERROR), and a descriptive message. The log captures all file loading operations, mapping executions, cell transfers, and any errors encountered. Users can scroll through the log history to troubleshoot issues or verify successful transfers. The log panel can be hidden at any time by clicking the \textbf  {Log} button again.}}{33}{figure.18}\protected@file@percent }
\newlabel{fig:logpanel}{{18}{33}{\textbf {Log panel} (toggled visible via the \textbf {Log} button in the header) showing detailed transfer execution logs. Each log entry includes a timestamp, severity level (INFO, WARNING, ERROR), and a descriptive message. The log captures all file loading operations, mapping executions, cell transfers, and any errors encountered. Users can scroll through the log history to troubleshoot issues or verify successful transfers. The log panel can be hidden at any time by clicking the \textbf {Log} button again}{figure.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces \textbf  {Create Month File confirmation dialog} showing the source template file and destination paths for new month files. The dialog lists each month file that will be created (e.g., ``May 2025'', ``June 2025'', ``July 2025'') along with its full destination path. The source template (e.g., ``Cost Control ZAG 04\_2025\_working.xlsm'') is displayed at the top. Click \textbf  {Yes} to proceed with file creation, or \textbf  {No} to cancel. Already-existing files are automatically skipped to prevent accidental overwrites.}}{34}{figure.19}\protected@file@percent }
\newlabel{fig:createconfirm}{{19}{34}{\textbf {Create Month File confirmation dialog} showing the source template file and destination paths for new month files. The dialog lists each month file that will be created (e.g., ``May 2025'', ``June 2025'', ``July 2025'') along with its full destination path. The source template (e.g., ``Cost Control ZAG 04\_2025\_working.xlsm'') is displayed at the top. Click \textbf {Yes} to proceed with file creation, or \textbf {No} to cancel. Already-existing files are automatically skipped to prevent accidental overwrites}{figure.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces \textbf  {File validation error dialog} displayed when the application detects a corrupt or invalid Excel file. The dialog shows the file path and error details (e.g., ``not a zip file'', ``missing workbook.xml'', ``file is locked''). Common causes include: file open in Excel, corrupted ZIP structure, or incomplete download. The dialog offers options to \textbf  {Replace} the file (browse for a valid replacement), \textbf  {Skip} the file (continue without it), or \textbf  {Cancel} the entire operation.}}{35}{figure.20}\protected@file@percent }
\newlabel{fig:fileerror}{{20}{35}{\textbf {File validation error dialog} displayed when the application detects a corrupt or invalid Excel file. The dialog shows the file path and error details (e.g., ``not a zip file'', ``missing workbook.xml'', ``file is locked''). Common causes include: file open in Excel, corrupted ZIP structure, or incomplete download. The dialog offers options to \textbf {Replace} the file (browse for a valid replacement), \textbf {Skip} the file (continue without it), or \textbf {Cancel} the entire operation}{figure.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces \textbf  {Transfer completion summary} showing the final results after an Execute All or Fill All Months operation completes. The summary displays: total mappings processed, successful transfers, failed transfers, total cells transferred, and execution time. Any warnings or errors are listed below with clickable links to jump to the relevant log entries. The \textbf  {Close} button dismisses the dialog. A green toast notification also appears at the bottom-center of the application window confirming successful completion.}}{36}{figure.21}\protected@file@percent }
\newlabel{fig:summary}{{21}{36}{\textbf {Transfer completion summary} showing the final results after an Execute All or Fill All Months operation completes. The summary displays: total mappings processed, successful transfers, failed transfers, total cells transferred, and execution time. Any warnings or errors are listed below with clickable links to jump to the relevant log entries. The \textbf {Close} button dismisses the dialog. A green toast notification also appears at the bottom-center of the application window confirming successful completion}{figure.21}{}}
