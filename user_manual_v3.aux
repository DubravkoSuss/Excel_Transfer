\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Individual Transfer} tab in its initial state. Browse for a \textit  {Source File} and \textit  {Destination File} using the \textbf  {Browse} buttons. Once files are loaded, the \textbf  {Select Source Cells (Graphical)} and \textbf  {Select Destination Cells (Graphical)} buttons become active for visual cell mapping. The \textit  {Transfer Mapping} table at the bottom shows all defined source-to-destination cell pairs ready for execution.}}{10}{figure.5}\protected@file@percent }
\newlabel{fig:logbutton}{{5}{10}{\textbf {Individual Transfer} tab in its initial state. Browse for a \textit {Source File} and \textit {Destination File} using the \textbf {Browse} buttons. Once files are loaded, the \textbf {Select Source Cells (Graphical)} and \textbf {Select Destination Cells (Graphical)} buttons become active for visual cell mapping. The \textit {Transfer Mapping} table at the bottom shows all defined source-to-destination cell pairs ready for execution}{figure.5}{}}
