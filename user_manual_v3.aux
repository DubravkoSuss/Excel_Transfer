\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \textbf  {Fill All Months} tab while a transfer is in progress for year 2025, target month March. The left sidebar lists \textit  {Active Mapping} cards for each discovered month (January, February shown). The scan results table on the right lists all found source files per month and mapping type (sap, budget\_refi, traffic\_mott, staff, pax\_transfer, sap\_ytd), each confirmed with a green checkmark. A progress dialog shows the current file loading stage at 0\%.}}{23}{figure.12}\protected@file@percent }
\newlabel{fig:individual}{{12}{23}{\textbf {Fill All Months} tab while a transfer is in progress for year 2025, target month March. The left sidebar lists \textit {Active Mapping} cards for each discovered month (January, February shown). The scan results table on the right lists all found source files per month and mapping type (sap, budget\_refi, traffic\_mott, staff, pax\_transfer, sap\_ytd), each confirmed with a green checkmark. A progress dialog shows the current file loading stage at 0\%}{figure.12}{}}
