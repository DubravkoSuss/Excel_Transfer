\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \textbf  {Fill All Months} tab while a transfer is in progress for year 2025, target month March. The left sidebar lists \textit  {Active Mapping} cards for each discovered month (January, February shown). The scan results table on the right lists all found source files per month and mapping type (sap, budget\_refi, traffic\_mott, staff, pax\_transfer, sap\_ytd), each confirmed with a green checkmark. A progress dialog shows the current file loading stage at 0\%.}}{25}{figure.12}\protected@file@percent }
\newlabel{fig:individual}{{12}{25}{\textbf {Fill All Months} tab while a transfer is in progress for year 2025, target month March. The left sidebar lists \textit {Active Mapping} cards for each discovered month (January, February shown). The scan results table on the right lists all found source files per month and mapping type (sap, budget\_refi, traffic\_mott, staff, pax\_transfer, sap\_ytd), each confirmed with a green checkmark. A progress dialog shows the current file loading stage at 0\%}{figure.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces \textbf  {Visual Cell Selector dialog} --- ``Select Source Cell'' mode. \textbf  {How to use}: \textbf  {Step 1}: At the top, use the \textbf  {Sheet} dropdown to switch between different sheets in the loaded workbook (e.g., Sheet1, MZLZ Consolidated, TRAFFIC mott). \textbf  {Step 2}: The grid displays the actual cell data from the Excel file --- rows 1--50 and columns A--Z are visible. Scroll horizontally or vertically to see more cells. \textbf  {Step 3}: \textbf  {Click any cell} in the grid to select it --- the cell highlights and the \textbf  {Column} and \textbf  {Row} fields below update automatically (e.g., Column: N, Row: 17). \textbf  {Step 4}: The \textbf  {``Selected:''} label shows the full cell reference in Excel notation (e.g., \texttt  {Sheet1!N17}). \textbf  {Step 5}: If you prefer, you can manually type the column letter and row number in the input fields instead of clicking. \textbf  {Step 6}: Click \textbf  {Apply} to confirm your selection and return to the Individual Transfer tab. The selected cell reference will appear in the Transfer Mapping table. \textbf  {Tip}: The highlighted area shows existing data in the source file, making it easy to identify which cells contain the values you need to transfer.}}{26}{figure.13}\protected@file@percent }
\newlabel{fig:cellselector}{{13}{26}{\textbf {Visual Cell Selector dialog} --- ``Select Source Cell'' mode. \textbf {How to use}: \textbf {Step 1}: At the top, use the \textbf {Sheet} dropdown to switch between different sheets in the loaded workbook (e.g., Sheet1, MZLZ Consolidated, TRAFFIC mott). \textbf {Step 2}: The grid displays the actual cell data from the Excel file --- rows 1--50 and columns A--Z are visible. Scroll horizontally or vertically to see more cells. \textbf {Step 3}: \textbf {Click any cell} in the grid to select it --- the cell highlights and the \textbf {Column} and \textbf {Row} fields below update automatically (e.g., Column: N, Row: 17). \textbf {Step 4}: The \textbf {``Selected:''} label shows the full cell reference in Excel notation (e.g., \texttt {Sheet1!N17}). \textbf {Step 5}: If you prefer, you can manually type the column letter and row number in the input fields instead of clicking. \textbf {Step 6}: Click \textbf {Apply} to confirm your selection and return to the Individual Transfer tab. The selected cell reference will appear in the Transfer Mapping table. \textbf {Tip}: The highlighted area shows existing data in the source file, making it easy to identify which cells contain the values you need to transfer}{figure.13}{}}
\@writefile{toc}{\contentsline {section}{\numberline {13}Data Flow Reference}{26}{section.13}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces \textbf  {Individual Transfer tab with 105 cells mapped} and ready for execution. The \textit  {Transfer Mapping} table lists all configured cell-to-cell transfers. \textbf  {Understanding the table}: Each row represents one cell transfer. The \textbf  {Source Cell} column shows where data will be read from (e.g., D4, C4, I4, H4, F4, E4, G4). The \textbf  {Current Value} column displays the actual data currently in that source cell (e.g., numbers, text, formulas). The \textbf  {Destination Cell} column shows where the data will be written to in the destination file. \textbf  {How to manage mappings}: Click the \textbf  {+ Add Mapping} button to add more cell pairs. Select a row and click \textbf  {Delete} to remove a mapping. Use \textbf  {Clear All} to start over. Click \textbf  {Import} to load mappings from a JSON file, or \textbf  {Export} to save your current mappings for reuse. \textbf  {Executing the transfer}: The \textbf  {Execute Transfer} button (green, at the bottom) becomes active once at least one mapping is configured. Click it to copy all mapped cells from the source file to the destination file in one operation. A progress dialog shows the transfer status. \textbf  {When to use this tab}: Use Individual Transfer for one-time data copies, custom cell mappings not covered by standard JSON mapping files, or when you need precise control over which specific cells are transferred.}}{27}{figure.14}\protected@file@percent }
\newlabel{fig:transfermapping}{{14}{27}{\textbf {Individual Transfer tab with 105 cells mapped} and ready for execution. The \textit {Transfer Mapping} table lists all configured cell-to-cell transfers. \textbf {Understanding the table}: Each row represents one cell transfer. The \textbf {Source Cell} column shows where data will be read from (e.g., D4, C4, I4, H4, F4, E4, G4). The \textbf {Current Value} column displays the actual data currently in that source cell (e.g., numbers, text, formulas). The \textbf {Destination Cell} column shows where the data will be written to in the destination file. \textbf {How to manage mappings}: Click the \textbf {+ Add Mapping} button to add more cell pairs. Select a row and click \textbf {Delete} to remove a mapping. Use \textbf {Clear All} to start over. Click \textbf {Import} to load mappings from a JSON file, or \textbf {Export} to save your current mappings for reuse. \textbf {Executing the transfer}: The \textbf {Execute Transfer} button (green, at the bottom) becomes active once at least one mapping is configured. Click it to copy all mapped cells from the source file to the destination file in one operation. A progress dialog shows the transfer status. \textbf {When to use this tab}: Use Individual Transfer for one-time data copies, custom cell mappings not covered by standard JSON mapping files, or when you need precise control over which specific cells are transferred}{figure.14}{}}
