\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Monthly Transfer} tab with multiple months selected across different years. The year cards for 2025 and 2026 are both expanded, showing individual month checkboxes. The \textbf  {Load Selected Periods} button at the bottom becomes active once at least one month is checked. The status bar indicates how many periods are currently selected.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:multimonth}{{4}{9}{\textbf {Monthly Transfer} tab with multiple months selected across different years. The year cards for 2025 and 2026 are both expanded, showing individual month checkboxes. The \textbf {Load Selected Periods} button at the bottom becomes active once at least one month is checked. The status bar indicates how many periods are currently selected}{figure.4}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.2.2}Working with Multiple Years}{9}{subsubsection.4.2.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Individual Transfer} tab in its initial state. \textbf  {Step 1}: Click the \textbf  {Browse} button next to \textit  {Source File} to select the Excel file you want to copy data FROM (e.g., SAP report, Traffic file). \textbf  {Step 2}: Click the \textbf  {Browse} button next to \textit  {Destination File} to select the Excel file you want to copy data TO (e.g., Cost Control workbook). \textbf  {Step 3}: Once both files are loaded, the \textbf  {Select Source Cells (Graphical)} button becomes active --- click it to open a visual grid where you can click cells to select them. \textbf  {Step 4}: Similarly, click \textbf  {Select Destination Cells (Graphical)} to choose where the data should be written. \textbf  {Step 5}: The \textit  {Transfer Mapping} table at the bottom shows all defined source-to-destination cell pairs. Each row displays the source cell reference (e.g., D4), its current value, and the destination cell reference. \textbf  {Step 6}: Click \textbf  {Execute Transfer} to copy all mapped cells from source to destination. Use this tab for one-off transfers or custom cell mappings not covered by the standard mapping files.}}{10}{figure.5}\protected@file@percent }
\newlabel{fig:logbutton}{{5}{10}{\textbf {Individual Transfer} tab in its initial state. \textbf {Step 1}: Click the \textbf {Browse} button next to \textit {Source File} to select the Excel file you want to copy data FROM (e.g., SAP report, Traffic file). \textbf {Step 2}: Click the \textbf {Browse} button next to \textit {Destination File} to select the Excel file you want to copy data TO (e.g., Cost Control workbook). \textbf {Step 3}: Once both files are loaded, the \textbf {Select Source Cells (Graphical)} button becomes active --- click it to open a visual grid where you can click cells to select them. \textbf {Step 4}: Similarly, click \textbf {Select Destination Cells (Graphical)} to choose where the data should be written. \textbf {Step 5}: The \textit {Transfer Mapping} table at the bottom shows all defined source-to-destination cell pairs. Each row displays the source cell reference (e.g., D4), its current value, and the destination cell reference. \textbf {Step 6}: Click \textbf {Execute Transfer} to copy all mapped cells from source to destination. Use this tab for one-off transfers or custom cell mappings not covered by the standard mapping files}{figure.5}{}}
